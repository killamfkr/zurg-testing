# Copy this file to .env and fill in your TorBox API key.
# Get your API key from https://torbox.app/settings

TORBOX_API_KEY=your_api_key_here

# FUSE mounts virtual files for Plex, VLC, and Infuse.
# Use strm instead if you run Jellyfin or Emby.
MOUNT_METHOD=fuse
MOUNT_PATH=/torbox

# Organize into movies/ and series/ via metadata API (can be slow or rate-limited).
# Leave false to put all videos in movies/ — recommended for first setup.
ENABLE_METADATA=false
RAW_MODE=false

# How often TorBox Media Center refreshes the mount.
# Options: slowest, very_slow, slow, normal, fast, ultra_fast, instant
MOUNT_REFRESH_TIME=normal

# Host path where media files are exposed (must match the docker-compose volume).
MOUNT_HOST_PATH=/mnt/torbox
